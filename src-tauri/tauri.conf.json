{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Svara",
  "version": "0.1.0",
  "identifier": "com.viratmankali.svara",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Svara",
        "width": 1,
        "height": 1,
        "resizable": true,
        "visible": false,
        "fullscreen": false
      },
      {
        "label": "settings",
        "title": "Svara Settings",
        "width": 1180,
        "height": 760,
        "resizable": false,
        "visible": false,
        "fullscreen": false
      },
      {
        "label": "history",
        "title": "Transcription History",
        "width": 480,
        "height": 680,
        "resizable": true,
        "visible": false,
        "fullscreen": false
      },
      {
        "label": "status",
        "title": "",
        "width": 230,
        "height": 72,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": null
    }
  }
}
